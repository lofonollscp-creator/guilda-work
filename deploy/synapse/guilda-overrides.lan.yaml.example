# Variante de guilda-overrides.yaml para probar Element en la red local
# ("opción 1": servidor en la LAN, sin exponerlo a internet — ver
# CASERO.md/plan de la fase de portátil) — identifica los endpoints de
# Hydra por la IP de la LAN (deploy/Caddyfile.lan) en vez de por
# *.localhost (esa variante es solo para pruebas dentro de esta misma
# máquina, ver guilda-overrides.local-https.yaml.example).
#
# Copia este archivo a guilda-overrides.lan.yaml (gitignored, igual que
# guilda-overrides.yaml) y rellena client_id/client_secret con los que
# imprima:
#   .venv/Scripts/python scripts/registrar_cliente_hydra.py --nombre element-lan \
#     --redirect-uri https://<TU_IP_LAN>:8446/_synapse/client/oidc/callback
#
# Sustituye TODAS las apariciones de 192.168.1.181 por la IP real de tu
# máquina en la LAN (la misma que GUILDA_LAN_IP en docker-compose.yml).
#
# El puerto de Hydra (8444) tiene que ser EL MISMO en `authorization_endpoint`
# (lo abre el navegador) y en `issuer`/`token_endpoint`/`userinfo_endpoint`/
# `jwks_uri` (los llama el propio contenedor de Synapse) — confirmado que
# el contenedor SÍ puede alcanzar la IP de la LAN del host directamente
# (sin necesitar un alias de red como en el mock de *.localhost).

public_baseurl: "https://192.168.1.181:8446/"

listeners:
  - port: 8008
    tls: false
    bind_addresses: ['::']
    type: http
    x_forwarded: true
    resources:
      - names: [client]
        compress: true
      - names: [federation]
        compress: false

federation_domain_whitelist: []

password_config:
  enabled: false
enable_registration: false

oidc_providers:
  - idp_id: guilda_work
    idp_name: "Guilda Work"
    issuer: "https://192.168.1.181:8444/"
    client_id: "RELLENA_CON_EL_CLIENT_ID_DE_element-lan"
    client_secret: "RELLENA_CON_EL_CLIENT_SECRET_DE_element-lan"
    client_auth_method: "client_secret_post"
    authorization_endpoint: "https://192.168.1.181:8444/oauth2/auth"
    token_endpoint: "https://192.168.1.181:8444/oauth2/token"
    userinfo_endpoint: "https://192.168.1.181:8444/userinfo"
    jwks_uri: "https://192.168.1.181:8444/.well-known/jwks.json"
    scopes: ["openid", "email", "profile"]
    user_mapping_provider:
      config:
        localpart_template: "{{ user.email.split('@')[0] }}"
        display_name_template: "{{ user.email }}"
        confirm_localpart: false
