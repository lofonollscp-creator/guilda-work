# Variante de guilda-overrides.yaml SOLO para verificar el login de
# Element/Synapse con el mock de HTTPS local (ver HTTPS_LOCAL.md, sección
# "Verificar Element") — nunca se usa en el día a día de desarrollo.
#
# Copia este archivo a guilda-overrides.local-https.yaml (gitignored, igual
# que guilda-overrides.yaml) y rellena client_id/client_secret con los que
# imprima:
#   .venv/Scripts/python scripts/registrar_cliente_hydra.py --nombre element-https-local \
#     --redirect-uri https://matrix.localhost:8443/_synapse/client/oidc/callback
#
# Única diferencia real con guilda-overrides.yaml: los endpoints de Hydra
# usan https://hydra.localhost:8443 (a través de caddy-local) en vez de
# los hostnames/puertos internos de Docker en plano — porque la librería
# OIDC de Synapse (authlib) exige "https://" de verdad incluso para las
# llamadas server-to-server (token/userinfo/jwks), algo que ni el hostname
# interno "hydra" en plano ni 127.0.0.1 satisfacen.
#
# El puerto 8443 tiene que ser EL MISMO tanto en `authorization_endpoint`
# (lo abre el navegador) como en `issuer`/`token_endpoint`/
# `userinfo_endpoint`/`jwks_uri` (los llama el propio contenedor de
# Synapse) — por eso caddy-local escucha en 8443 tanto puertas afuera
# (publicado al host) como puertas adentro (dentro de la red de Docker,
# ver deploy/Caddyfile.local). Si no coincidieran, el `iss` que trae el
# token que emite Hydra (siempre con el puerto público) no encajaría con
# el `issuer` configurado aquí, y Synapse rechazaría el token con
# `invalid_claim: Invalid claim 'iss'` (encontrado verificando Element).
#
# Synapse necesita además confiar en la CA de caddy-local para poder
# verificar el certificado (ver docker-compose.synapse-https-local.yml,
# que monta el certificado y fija SSL_CERT_FILE).

public_baseurl: "https://matrix.localhost:8443/"

# Sin esto, Synapse ve la conexión que le reenvía Caddy en plano (Caddy
# termina TLS y reenvía por HTTP dentro de la red de Docker) y no confía
# en X-Forwarded-Proto — el login SSO entra en un bucle infinito de
# redirecciones a sí mismo porque Synapse cree que la petición es http
# aunque el navegador use https de verdad. Mismo tipo de bug que el de
# Hydra (SERVE_COOKIES_SECURE) ya corregido para Outline — ver
# HTTPS_LOCAL.md.
listeners:
  - port: 8008
    tls: false
    bind_addresses: ['::']
    type: http
    x_forwarded: true
    resources:
      - names: [client]
        compress: true
      - names: [federation]
        compress: false

federation_domain_whitelist: []

password_config:
  enabled: false
enable_registration: false

oidc_providers:
  - idp_id: guilda_work
    idp_name: "Guilda Work"
    issuer: "https://hydra.localhost:8443/"
    client_id: "RELLENA_CON_EL_CLIENT_ID_DE_element-https-local"
    client_secret: "RELLENA_CON_EL_CLIENT_SECRET_DE_element-https-local"
    client_auth_method: "client_secret_post"
    authorization_endpoint: "https://hydra.localhost:8443/oauth2/auth"
    token_endpoint: "https://hydra.localhost:8443/oauth2/token"
    userinfo_endpoint: "https://hydra.localhost:8443/userinfo"
    jwks_uri: "https://hydra.localhost:8443/.well-known/jwks.json"
    scopes: ["openid", "email", "profile"]
    user_mapping_provider:
      config:
        localpart_template: "{{ user.email.split('@')[0] }}"
        display_name_template: "{{ user.email }}"
        confirm_localpart: false
