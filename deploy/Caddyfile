# Plantilla de Caddyfile para servir Guilda Work y el resto del stack de
# Docker (Fase 3c de HOSTING.md, ver también la sección "Fase 7c" del
# plan de integraciones) detrás de un proxy inverso con HTTPS automático.
# Copia este archivo a /etc/caddy/Caddyfile en el VPS y sustituye HOSTNAME
# por tu hostname real (ver más abajo) antes de arrancar Caddy.
#
# Sin dominio propio todavía: usa un hostname de sslip.io, que resuelve
# automáticamente a la IP del servidor y permite a Caddy pedir un
# certificado Let's Encrypt real sin necesitar comprar un dominio. Si la IP
# del VPS es 203.0.113.10, el hostname sería:
#
#   203-0-113-10.sslip.io
#
# Cuando compres un dominio de verdad, solo hay que cambiar HOSTNAME por
# ese dominio (y los subdominios de abajo) aquí y crear los registros DNS
# A correspondientes — Caddy pide los nuevos certificados solo, sin más
# pasos.
#
# Cada bloque de abajo corresponde a un puerto publicado en 127.0.0.1 por
# docker-compose.yml/HOSTING.md — Caddy es la ÚNICA vía de entrada real
# desde internet a cualquiera de estos servicios (ver la nota de
# seguridad en la cabecera de docker-compose.yml sobre por qué los
# puertos publicados NUNCA quedan en 0.0.0.0).

app.HOSTNAME {
	reverse_proxy localhost:8000
}

# Hydra: el navegador la visita directamente durante el OAuth2 (a
# diferencia de Kratos, que siempre queda detrás de /.ory/ en app.HOSTNAME)
# — necesita su propio subdominio con HTTPS real. Solo el puerto público
# (4444) se publica aquí; el admin (4445) NUNCA se expone, ni siquiera vía
# Caddy — gestión de clientes OAuth2 solo desde el propio servidor
# (scripts/registrar_cliente_hydra.py).
hydra.HOSTNAME {
	reverse_proxy localhost:4444
}

outline.HOSTNAME {
	reverse_proxy localhost:3001
}

# Element (interfaz de chat) — sirve la SPA estática.
chat.HOSTNAME {
	reverse_proxy localhost:8009
}

# Synapse (API de Matrix) — el navegador la visita directamente durante
# el login SSO (mismo motivo que hydra.HOSTNAME arriba), y Synapse
# también la usa para sus propias llamadas OIDC server-to-server (ver
# HOSTING.md 8.9 — a diferencia de Kratos/Outline, aquí no hace falta
# ningún hostname interno de Docker, la misma URL pública vale para todo
# porque la librería OIDC de Synapse exige HTTPS de verdad en cualquier
# caso).
matrix.HOSTNAME {
	reverse_proxy localhost:8008
}

# Opcionales — solo si quieres acceder a estos paneles desde fuera del
# servidor. Si prefieres mantenerlos solo accesibles por SSH (túnel local,
# `ssh -L 3000:localhost:3000 guilda@tu-servidor`), simplemente no los
# publiques aquí y bórralos de esta plantilla.
metabase.HOSTNAME {
	reverse_proxy localhost:3000
}

n8n.HOSTNAME {
	reverse_proxy localhost:5678
}

minio.HOSTNAME {
	reverse_proxy localhost:9001
}
